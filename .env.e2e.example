# Copy to .env.e2e.local for local production E2E runs (never commit secrets)

# Target app URL — use production for real smoke tests
PLAYWRIGHT_BASE_URL=https://incluhub-manager-git-main-pritam2k4s-projects.vercel.app

# Required when Vercel Deployment Protection is enabled (Project → Settings → Deployment Protection)
VERCEL_AUTOMATION_BYPASS_SECRET=your-bypass-secret-from-vercel

# Supabase (for seed script — same as .env.local)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Existing accounts (real passwords)
E2E_SUPER_ADMIN_EMAIL=preetam.naik3@gmail.com
E2E_SUPER_ADMIN_PASSWORD=your-password
E2E_MANAGER_EMAIL=contact@incluhub.in
E2E_MANAGER_PASSWORD=your-password

# Dedicated test users (created by npm run test:e2e:seed)
E2E_EDITOR_EMAIL=e2e-editor@incluhub.in
E2E_VIEWER_EMAIL=e2e-viewer@incluhub.in
E2E_CLIENT_EMAIL=e2e-client@incluhub.in
E2E_TEST_PASSWORD=use-a-strong-shared-test-password
